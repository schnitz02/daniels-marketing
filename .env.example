# ── Anthropic ────────────────────────────────────────────
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ── Higgsfield (AI image + video generation) ─────────────
# Get from: https://higgsfield.ai/dashboard
HIGGSFIELD_API_KEY=

# ── Meta (Instagram + Facebook) ──────────────────────────
# Create a Meta App at: https://developers.facebook.com
META_APP_ID=
META_APP_SECRET=
# Long-lived Page Access Token (never expires if refreshed)
META_ACCESS_TOKEN=
# Facebook Page ID for Daniel's Donuts
META_PAGE_ID=
# Instagram Business Account ID linked to the page
META_IG_ACCOUNT_ID=

# ── TikTok ───────────────────────────────────────────────
# Create app at: https://developers.tiktok.com
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=

# ── WordPress (danielsdonuts.com.au) ─────────────────────
# WP_APP_PASSWORD: generate via WP Admin > Users > Application Passwords
# (NOT your login password)
WP_URL=https://your-wordpress-site.example.com
WP_USERNAME=
WP_APP_PASSWORD=

# ── Database ─────────────────────────────────────────────
# Dev: sqlite:///./daniels_marketing.db (default, no setup needed)
# Prod: postgresql://user:password@localhost:5432/daniels_marketing
DATABASE_URL=sqlite:///./daniels_marketing.db

# ── Redis (task queue + scheduling) ──────────────────────
REDIS_URL=redis://localhost:6379

# ── Media storage ────────────────────────────────────────
# Directory where generated images and videos are stored
MEDIA_DIR=./media

# ── Internal API ─────────────────────────────────────────
# Set a secret key to protect the agent trigger endpoint from CSRF/unauthorized calls
# Leave empty in development to disable the check
AGENT_API_KEY=
